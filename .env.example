# ==============================================================================
# SECURE CONFIGURATION BLUEPRINT FOR FRAUDSHIELD AI / AEGIS-9
# ==============================================================================
# Copy this file to .env or configure these variables in Vercel/Cloud Run.
# Ensure no secrets or real developer API keys are ever committed to repository files.

# 1. CORE INTELLIGENCE ENGINES
# ------------------------------------------------------------------------------
# Gemini API Key for Server-Side AI Forensic and Chat analysis.
# In production, DO NOT use NEXT_PUBLIC_ prefixes to prevent client-side leakage.
# Configure this inside your cloud provider secrets manager (e.g., Google Secrets Manager or Vercel Environment Variables).
GEMINI_API_KEY="your_secure_gemini_api_key_here"

# 2. RUNTIME AND NETWORK DEPLOYMENT
# ------------------------------------------------------------------------------
# High-confidence self-referrent URL used for secure headers, absolute path maps, and absolute webhook redirects.
# Defaults to your production subdomain (e.g., https://fraudshield.vercel.app or Google Cloud Run Service URL).
APP_URL="https://your-production-app-url.com"

# 3. PRODUCTION SYSTEM CONTROLS
# ------------------------------------------------------------------------------
# Controls React strict-mode warnings and asset path resolutions.
NODE_ENV="production"

# Disable HMR (Hot Module Replacement) inside testing environments (Leave undefined or false for standard production builds).
DISABLE_HMR="false"
